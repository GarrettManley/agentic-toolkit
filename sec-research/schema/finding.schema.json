{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sec-research.local/schema/finding.schema.json",
  "title": "Finding",
  "description": "Frontmatter for findings/<trace>/finding.md. Captures all metadata required for: PoC reproduction, anti-fabrication validation, deduplication checking, and submission gate.",
  "type": "object",
  "required": [
    "trace_id", "title", "program_slug", "vuln_class", "severity",
    "status", "discovered_at", "target", "evidence", "poc", "citations",
    "deduplication_check"
  ],
  "additionalProperties": false,
  "properties": {
    "trace_id": {
      "type": "string",
      "pattern": "^FIND-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{3}$",
      "description": "FIND-YYYY-MM-DD-NNN; auto-generated by PoT-1 hook"
    },
    "title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 200
    },
    "program_slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "vuln_class": {
      "enum": [
        "supply-chain-malicious-pkg",
        "dependency-cve",
        "code-injection",
        "auth-bypass",
        "ssrf",
        "rce",
        "info-disclosure",
        "dos",
        "crypto-weakness",
        "logic-flaw",
        "other"
      ]
    },
    "cwe_ids": {
      "type": "array",
      "items": {"type": "string", "pattern": "^CWE-[0-9]+$"},
      "uniqueItems": true
    },
    "severity": {
      "type": "object",
      "required": ["cvss_v3_1_vector", "cvss_v3_1_score", "rationale"],
      "additionalProperties": false,
      "properties": {
        "cvss_v3_1_vector": {
          "type": "string",
          "pattern": "^CVSS:3\\.1/.*"
        },
        "cvss_v3_1_score": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 10.0
        },
        "cvss_v4_vector": {
          "type": "string",
          "pattern": "^CVSS:4\\.0/.*"
        },
        "cvss_v4_score": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 10.0
        },
        "rationale": {
          "type": "string",
          "minLength": 20,
          "description": "Human-readable explanation of how the score was derived"
        }
      }
    },
    "status": {
      "enum": [
        "draft-incomplete",
        "draft-complete",
        "verifying",
        "ready-for-review",
        "approved-to-submit",
        "submitted",
        "submitted-manual",
        "accepted",
        "rejected",
        "duplicate",
        "informational"
      ]
    },
    "discovered_at": {
      "type": "string",
      "format": "date-time"
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "venue_response": {
      "type": "string",
      "description": "Venue-assigned ID/URL once submitted"
    },
    "target": {
      "type": "object",
      "required": ["asset_type", "identifier"],
      "additionalProperties": false,
      "properties": {
        "asset_type": {
          "enum": ["package", "repo", "url", "host"]
        },
        "identifier": {"type": "string"},
        "version_or_revision": {
          "type": "string",
          "description": "Specific version (pkg@1.2.3) or commit SHA being analyzed"
        },
        "ecosystem": {
          "enum": ["npm", "pypi", "cargo", "maven", "gem", "nuget", "go", "rubygems", "composer"]
        }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["timeline_path", "redacted_dir", "verification_path"],
      "additionalProperties": false,
      "properties": {
        "timeline_path": {"type": "string", "const": "timeline.md"},
        "redacted_dir": {"type": "string", "const": "evidence/redacted/"},
        "verification_path": {"type": "string", "const": "verification.json"}
      }
    },
    "poc": {
      "type": "object",
      "required": ["reproduce_script", "expected_exit_code", "deterministic"],
      "additionalProperties": false,
      "properties": {
        "reproduce_script": {
          "type": "string",
          "const": "poc/reproduce.sh"
        },
        "expected_exit_code": {
          "type": "integer",
          "minimum": 0
        },
        "expected_output_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "SHA-256 of stdout — required if deterministic=true"
        },
        "deterministic": {"type": "boolean"},
        "preconditions": {
          "type": "array",
          "items": {"type": "string"}
        },
        "non_deterministic_rationale": {
          "type": "string",
          "description": "Required if deterministic=false; explain what varies"
        }
      },
      "if": {"properties": {"deterministic": {"const": true}}},
      "then": {"required": ["expected_output_hash"]}
    },
    "citations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["claim", "source_url", "source_tier", "accessed_at"],
        "additionalProperties": false,
        "properties": {
          "claim": {"type": "string", "minLength": 10},
          "source_url": {"type": "string", "format": "uri"},
          "source_tier": {"enum": [1, 2, 3]},
          "corroborator_url": {
            "type": "string",
            "format": "uri",
            "description": "Required when source_tier === 3"
          },
          "accessed_at": {"type": "string", "format": "date-time"}
        },
        "if": {"properties": {"source_tier": {"const": 3}}},
        "then": {"required": ["corroborator_url"]}
      }
    },
    "deduplication_check": {
      "type": "object",
      "required": ["checked_against", "matches", "checked_at"],
      "additionalProperties": false,
      "properties": {
        "checked_against": {
          "type": "array",
          "minItems": 1,
          "items": {"enum": ["nvd", "ghsa", "osv", "program-disclosed", "venue-dupe-api"]}
        },
        "matches": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["source", "match_url", "similarity"],
            "properties": {
              "source": {"type": "string"},
              "match_url": {"type": "string", "format": "uri"},
              "similarity": {
                "enum": ["exact-dup", "near-match", "related", "false-positive"]
              },
              "notes": {"type": "string"}
            }
          }
        },
        "checked_at": {"type": "string", "format": "date-time"}
      }
    },
    "ai_assistance_disclosure": {
      "type": "string",
      "description": "Required if program rules ai_disclosure_required=true. Free text explaining how AI was used."
    },
    "keep_emojis": {
      "type": "boolean",
      "description": "Per-finding override of scrub_emojis post-processing"
    }
  }
}
