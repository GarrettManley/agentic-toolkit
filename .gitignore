# Ignore all top-level files/folders by default
/*

# Allow-list for Workspace Configuration
!.gitignore
!.ai/
!.claude/
!CLAUDE.md
!_scripts/
!docs/
!README.md
!site/
!sec-research/
!publish.ps1

# sec-research/ exclusions (runtime artifacts, raw evidence, used tokens)
sec-research/runtime/
sec-research/findings/**/evidence/raw/
sec-research/overrides/used/
sec-research/submissions/tokens/
sec-research/__pycache__/
sec-research/**/__pycache__/
sec-research/**/*.pyc
# Append-only audit ledger: churns on every nightly run; not source of truth to track
sec-research/submissions/ledger.jsonl

# Local Claude/agent settings (per-machine, not source)
**/*.local.json

# Hugo build artifacts (generated by `hugo` in site/)
site/public/
site/.hugo_build.lock
site/hugo.toml.bak

# Vendored Hugo theme — a raw upstream `git clone` (own .git, not a submodule);
# treated as a local dependency, not tracked. To make reproducible, convert to a
# submodule instead.
site/themes/
